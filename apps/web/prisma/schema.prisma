generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  CASHIER
  BARISTA
  VIEWER

  @@map("user_role")
}

enum OrderType {
  TAKEAWAY
  DINE_IN
  DELIVERY

  @@map("order_type")
}

enum OrderStatus {
  DRAFT
  SENT
  PREPARING
  READY
  SERVED
  CLOSED
  CANCELLED

  @@map("order_status")
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED

  @@map("payment_status")
}

enum OrderItemStatus {
  NEW
  SENT
  PREPARING
  READY
  SERVED
  CANCELLED

  @@map("order_item_status")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  QR
  CARD
  OTHER

  @@map("payment_method")
}

enum PaymentRecordStatus {
  PENDING
  CONFIRMED
  VOIDED
  REFUNDED

  @@map("payment_record_status")
}

enum PaymentReconciliationStatus {
  NOT_REQUIRED
  PENDING
  MANUAL_CONFIRMED
  AUTO_CONFIRMED
  EXPIRED
  CANCELLED
  FAILED

  @@map("payment_reconciliation_status")
}

enum ShiftStatus {
  OPEN
  CLOSED

  @@map("shift_status")
}

enum InventoryStockMovementType {
  PURCHASE
  ADJUSTMENT
  WASTE
  CORRECTION

  @@map("inventory_stock_movement_type")
}

enum InventoryUploadType {
  INVOICE
  IMPORT

  @@map("inventory_upload_type")
}

enum InventoryUploadStatus {
  STORED
  PARSED
  ATTACHED
  FAILED

  @@map("inventory_upload_status")
}

enum InventoryImportBatchStatus {
  DRAFT
  PARSED
  CONFIRMED
  FAILED

  @@map("inventory_import_batch_status")
}

enum InventoryImportSourceType {
  TXT
  EXCEL
  UNKNOWN

  @@map("inventory_import_source_type")
}

enum InventoryImportParserUsed {
  DETERMINISTIC
  GEMINI
  MIXED

  @@map("inventory_import_parser_used")
}

enum InventoryImportRowStatus {
  VALID
  INVALID
  WARNING
  CONFIRMED
  SKIPPED

  @@map("inventory_import_row_status")
}

enum ProductRecipeTargetType {
  MENU_ITEM
  MENU_VARIANT

  @@map("product_recipe_target_type")
}

enum ProductCostSnapshotSource {
  RECIPE_UPDATE
  SALE

  @@map("product_cost_snapshot_source")
}

enum EmployeeEmploymentStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED

  @@map("employee_employment_status")
}

enum StaffScheduleRole {
  BAR
  CASHIER
  SERVICE
  MANAGER

  @@map("staff_schedule_role")
}

enum StaffScheduleStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED

  @@map("staff_schedule_status")
}

enum TimeClockEntryStatus {
  OPEN
  CLOSED
  MISSED_PUNCH
  NEEDS_REVIEW
  APPROVED

  @@map("time_clock_entry_status")
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED

  @@map("timesheet_status")
}

enum TimesheetAdjustmentType {
  TIME_CORRECTION
  BREAK_CORRECTION
  MANAGER_NOTE

  @@map("timesheet_adjustment_type")
}

enum PayrollRunStatus {
  DRAFT
  REVIEWED
  APPROVED

  @@map("payroll_run_status")
}

enum PayrollAdjustmentType {
  BONUS
  DEDUCTION

  @@map("payroll_adjustment_type")
}

enum DormRoomStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE

  @@map("dorm_room_status")
}

enum DormBedStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
  RESERVED

  @@map("dorm_bed_status")
}

enum DormLeaseStatus {
  ACTIVE
  NOTICE_GIVEN
  ENDED
  CANCELLED

  @@map("dorm_lease_status")
}

enum DormInvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  VOIDED

  @@map("dorm_invoice_status")
}

enum DormPaymentMethod {
  CASH
  BANK_TRANSFER
  QR
  CARD
  OTHER

  @@map("dorm_payment_method")
}

model User {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  username    String    @unique
  displayName String    @map("display_name")
  pinHash     String    @map("pin_hash")
  role        UserRole
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  orders                  Order[]
  payments                Payment[]
  openedShifts            Shift[]                  @relation("ShiftOpenedBy")
  closedShifts            Shift[]                  @relation("ShiftClosedBy")
  inventoryStockMovements InventoryStockMovement[]
  inventoryUploads        InventoryUpload[]
  inventoryImportBatches  InventoryImportBatch[]
  employeeProfile         EmployeeProfile?
  createdDormLeases       DormLease[]             @relation("DormLeaseCreatedBy")
  receivedDormPayments    DormPayment[]           @relation("DormPaymentReceivedBy")

  @@map("users")
}

model DormSite {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name      String   @unique(map: "dorm_sites_name_uidx")
  address   String?
  note      String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  rooms DormRoom[]

  @@index([isActive, name], map: "dorm_sites_isActive_name_idx")
  @@map("dorm_sites")
}

model DormRoom {
  id        String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  siteId    String         @map("site_id") @db.Uuid
  code      String
  name      String
  status    DormRoomStatus @default(ACTIVE)
  note      String?
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  site DormSite  @relation(fields: [siteId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  beds DormBed[]

  @@unique([siteId, code], map: "dorm_rooms_siteId_code_uidx")
  @@index([siteId, status], map: "dorm_rooms_siteId_status_idx")
  @@map("dorm_rooms")
}

model DormBed {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  roomId          String        @map("room_id") @db.Uuid
  code            String
  status          DormBedStatus @default(VACANT)
  monthlyRentVnd  BigInt        @default(0) @map("monthly_rent_vnd")
  note            String?
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  room   DormRoom    @relation(fields: [roomId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  leases DormLease[]

  @@unique([roomId, code], map: "dorm_beds_roomId_code_uidx")
  @@index([roomId, status], map: "dorm_beds_roomId_status_idx")
  @@map("dorm_beds")
}

model DormTenant {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fullName         String   @map("full_name")
  phone            String
  email            String?
  identityNumber   String?  @map("identity_number")
  emergencyContact String?  @map("emergency_contact")
  note             String?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  leases DormLease[]

  @@index([fullName], map: "dorm_tenants_fullName_idx")
  @@index([phone], map: "dorm_tenants_phone_idx")
  @@map("dorm_tenants")
}

model DormLease {
  id             String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId       String          @map("tenant_id") @db.Uuid
  bedId          String          @map("bed_id") @db.Uuid
  startDate      DateTime        @map("start_date") @db.Date
  endDate        DateTime?       @map("end_date") @db.Date
  dueDay         Int             @default(5) @map("due_day")
  monthlyRentVnd BigInt          @map("monthly_rent_vnd")
  depositVnd     BigInt          @default(0) @map("deposit_vnd")
  status         DormLeaseStatus @default(ACTIVE)
  note           String?
  createdById    String?         @map("created_by_id") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    DormTenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  bed       DormBed       @relation(fields: [bedId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  createdBy User?         @relation("DormLeaseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  invoices  DormInvoice[]

  @@index([tenantId, status], map: "dorm_leases_tenantId_status_idx")
  @@index([bedId, status], map: "dorm_leases_bedId_status_idx")
  @@index([status, startDate], map: "dorm_leases_status_startDate_idx")
  @@map("dorm_leases")
}

model DormInvoice {
  id           String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  leaseId      String            @map("lease_id") @db.Uuid
  invoiceNo    String            @unique(map: "dorm_invoices_invoiceNo_uidx") @map("invoice_no")
  billingMonth DateTime          @map("billing_month") @db.Date
  dueDate      DateTime          @map("due_date") @db.Date
  subtotalVnd  BigInt            @default(0) @map("subtotal_vnd")
  totalVnd     BigInt            @default(0) @map("total_vnd")
  paidVnd      BigInt            @default(0) @map("paid_vnd")
  status       DormInvoiceStatus @default(DRAFT)
  note         String?
  issuedAt     DateTime?         @map("issued_at") @db.Timestamptz(6)
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  lease    DormLease         @relation(fields: [leaseId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  items    DormInvoiceItem[]
  payments DormPayment[]

  @@unique([leaseId, billingMonth], map: "dorm_invoices_leaseId_billingMonth_uidx")
  @@index([status, dueDate], map: "dorm_invoices_status_dueDate_idx")
  @@index([billingMonth], map: "dorm_invoices_billingMonth_idx")
  @@map("dorm_invoices")
}

model DormInvoiceItem {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
  description String
  quantity    Int      @default(1)
  unitAmount  BigInt   @map("unit_amount")
  lineTotal   BigInt   @map("line_total")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  invoice DormInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([invoiceId, sortOrder], map: "dorm_invoice_items_invoiceId_sortOrder_idx")
  @@map("dorm_invoice_items")
}

model DormPayment {
  id           String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  invoiceId    String            @map("invoice_id") @db.Uuid
  amountVnd    BigInt            @map("amount_vnd")
  method       DormPaymentMethod
  reference    String?
  receivedAt   DateTime          @default(now()) @map("received_at") @db.Timestamptz(6)
  receivedById String?           @map("received_by_id") @db.Uuid
  note         String?
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  invoice    DormInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  receivedBy User?       @relation("DormPaymentReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([invoiceId, receivedAt], map: "dorm_payments_invoiceId_receivedAt_idx")
  @@index([receivedAt], map: "dorm_payments_receivedAt_idx")
  @@map("dorm_payments")
}

model EmployeeProfile {
  id               String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId           String?                  @unique(map: "employee_profiles_userId_uidx") @map("user_id") @db.Uuid
  employeeCode     String?                  @unique(map: "employee_profiles_employeeCode_uidx") @map("employee_code")
  displayName      String                   @map("display_name")
  role             UserRole
  scheduleRole     StaffScheduleRole        @default(SERVICE) @map("schedule_role")
  phone            String?
  email            String?
  employmentStatus EmployeeEmploymentStatus @default(ACTIVE) @map("employment_status")
  hourlyRateVnd    BigInt?                  @map("hourly_rate_vnd")
  salaryMetadata   Json?                    @map("salary_metadata")
  hiredAt          DateTime?                @map("hired_at") @db.Timestamptz(6)
  terminatedAt     DateTime?                @map("terminated_at") @db.Timestamptz(6)
  note             String?
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  user         User?                 @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  schedules    StaffSchedule[]
  clockEntries TimeClockEntry[]
  timesheets   Timesheet[]
  adjustments  TimesheetAdjustment[]
  payrollLines PayrollLine[]

  @@index([employmentStatus, displayName], map: "employee_profiles_employmentStatus_displayName_idx")
  @@index([role], map: "employee_profiles_role_idx")
  @@index([scheduleRole], map: "employee_profiles_scheduleRole_idx")
  @@map("employee_profiles")
}

model StaffSchedule {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  employeeProfileId String              @map("employee_profile_id") @db.Uuid
  scheduleDate      DateTime            @map("schedule_date") @db.Date
  scheduledStartAt  DateTime            @map("scheduled_start_at") @db.Timestamptz(6)
  scheduledEndAt    DateTime            @map("scheduled_end_at") @db.Timestamptz(6)
  role              StaffScheduleRole
  status            StaffScheduleStatus @default(SCHEDULED)
  note              String?
  createdById       String?             @map("created_by_id") @db.Uuid
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  employeeProfile EmployeeProfile  @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  clockEntries    TimeClockEntry[]

  @@index([employeeProfileId, scheduleDate], map: "staff_schedules_employeeProfileId_scheduleDate_idx")
  @@index([scheduleDate, role], map: "staff_schedules_scheduleDate_role_idx")
  @@index([status, scheduleDate], map: "staff_schedules_status_scheduleDate_idx")
  @@map("staff_schedules")
}

model TimeClockEntry {
  id                String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  employeeProfileId String               @map("employee_profile_id") @db.Uuid
  userId            String?              @map("user_id") @db.Uuid
  scheduleId        String?              @map("schedule_id") @db.Uuid
  clockInAt         DateTime             @map("clock_in_at") @db.Timestamptz(6)
  clockOutAt        DateTime?            @map("clock_out_at") @db.Timestamptz(6)
  breakMinutes      Int                  @default(0) @map("break_minutes")
  status            TimeClockEntryStatus @default(OPEN)
  exceptions        Json                 @default("[]")
  lateMinutes       Int                  @default(0) @map("late_minutes")
  earlyLeaveMinutes Int                  @default(0) @map("early_leave_minutes")
  overtimeMinutes   Int                  @default(0) @map("overtime_minutes")
  missedPunch       Boolean              @default(false) @map("missed_punch")
  note              String?
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  employeeProfile EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  schedule        StaffSchedule?  @relation(fields: [scheduleId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([employeeProfileId, clockInAt], map: "time_clock_entries_employeeProfileId_clockInAt_idx")
  @@index([scheduleId], map: "time_clock_entries_scheduleId_idx")
  @@index([status, clockInAt], map: "time_clock_entries_status_clockInAt_idx")
  @@map("time_clock_entries")
}

model Timesheet {
  id                 String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  employeeProfileId  String          @map("employee_profile_id") @db.Uuid
  periodStart        DateTime        @map("period_start") @db.Date
  periodEnd          DateTime        @map("period_end") @db.Date
  status             TimesheetStatus @default(DRAFT)
  totalWorkedMinutes Int             @default(0) @map("total_worked_minutes")
  totalBreakMinutes  Int             @default(0) @map("total_break_minutes")
  lateMinutes        Int             @default(0) @map("late_minutes")
  earlyLeaveMinutes  Int             @default(0) @map("early_leave_minutes")
  overtimeMinutes    Int             @default(0) @map("overtime_minutes")
  exceptionCount     Int             @default(0) @map("exception_count")
  submittedAt        DateTime?       @map("submitted_at") @db.Timestamptz(6)
  approvedAt         DateTime?       @map("approved_at") @db.Timestamptz(6)
  approvedById       String?         @map("approved_by_id") @db.Uuid
  note               String?
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  employeeProfile EmployeeProfile       @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  adjustments     TimesheetAdjustment[]
  payrollLines    PayrollLine[]

  @@unique([employeeProfileId, periodStart, periodEnd], map: "timesheets_employee_period_uidx")
  @@index([periodStart, periodEnd], map: "timesheets_period_idx")
  @@index([status, periodStart], map: "timesheets_status_periodStart_idx")
  @@map("timesheets")
}

model TimesheetAdjustment {
  id                String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  timesheetId       String                  @map("timesheet_id") @db.Uuid
  employeeProfileId String                  @map("employee_profile_id") @db.Uuid
  adjustmentType    TimesheetAdjustmentType @map("adjustment_type")
  minutesDelta      Int                     @default(0) @map("minutes_delta")
  reason            String
  createdById       String?                 @map("created_by_id") @db.Uuid
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)

  timesheet       Timesheet       @relation(fields: [timesheetId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  employeeProfile EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([employeeProfileId, createdAt], map: "timesheet_adjustments_employeeProfileId_createdAt_idx")
  @@index([timesheetId], map: "timesheet_adjustments_timesheetId_idx")
  @@map("timesheet_adjustments")
}

model PayrollPeriod {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  periodStart DateTime @map("period_start") @db.Date
  periodEnd   DateTime @map("period_end") @db.Date
  label       String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  runs PayrollRun[]

  @@unique([periodStart, periodEnd], map: "payroll_periods_period_uidx")
  @@index([periodStart, periodEnd], map: "payroll_periods_period_idx")
  @@map("payroll_periods")
}

model PayrollRun {
  id            String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  periodId      String           @map("period_id") @db.Uuid
  status        PayrollRunStatus @default(DRAFT)
  generatedById String?          @map("generated_by_id") @db.Uuid
  reviewedAt    DateTime?        @map("reviewed_at") @db.Timestamptz(6)
  approvedAt    DateTime?        @map("approved_at") @db.Timestamptz(6)
  note          String?
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  period PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  lines  PayrollLine[]

  @@unique([periodId], map: "payroll_runs_periodId_uidx")
  @@index([status, createdAt], map: "payroll_runs_status_createdAt_idx")
  @@map("payroll_runs")
}

model PayrollLine {
  id                    String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  runId                 String   @map("run_id") @db.Uuid
  employeeProfileId     String   @map("employee_profile_id") @db.Uuid
  timesheetId           String   @map("timesheet_id") @db.Uuid
  approvedWorkedMinutes Int      @default(0) @map("approved_worked_minutes")
  regularMinutes        Int      @default(0) @map("regular_minutes")
  overtimeMinutes       Int      @default(0) @map("overtime_minutes")
  hourlyRateVnd         BigInt?  @map("hourly_rate_vnd")
  fixedSalaryVnd        BigInt?  @map("fixed_salary_vnd")
  overtimeMultiplier    Decimal  @default(1.5) @map("overtime_multiplier") @db.Decimal(6, 2)
  regularPayVnd         BigInt   @default(0) @map("regular_pay_vnd")
  fixedPayVnd           BigInt   @default(0) @map("fixed_pay_vnd")
  overtimePayVnd        BigInt   @default(0) @map("overtime_pay_vnd")
  bonusVnd              BigInt   @default(0) @map("bonus_vnd")
  deductionVnd          BigInt   @default(0) @map("deduction_vnd")
  grossPayVnd           BigInt   @default(0) @map("gross_pay_vnd")
  netPayVnd             BigInt   @default(0) @map("net_pay_vnd")
  calculationMetadata   Json     @default("{}") @map("calculation_metadata")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  run             PayrollRun          @relation(fields: [runId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  employeeProfile EmployeeProfile     @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  timesheet       Timesheet           @relation(fields: [timesheetId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  adjustments     PayrollAdjustment[]

  @@unique([runId, employeeProfileId, timesheetId], map: "payroll_lines_run_employee_timesheet_uidx")
  @@index([employeeProfileId], map: "payroll_lines_employeeProfileId_idx")
  @@index([timesheetId], map: "payroll_lines_timesheetId_idx")
  @@map("payroll_lines")
}

model PayrollAdjustment {
  id             String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  lineId         String                @map("line_id") @db.Uuid
  adjustmentType PayrollAdjustmentType @map("adjustment_type")
  amountVnd      BigInt                @map("amount_vnd")
  reason         String
  createdById    String?               @map("created_by_id") @db.Uuid
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  line PayrollLine @relation(fields: [lineId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([lineId, createdAt], map: "payroll_adjustments_lineId_createdAt_idx")
  @@map("payroll_adjustments")
}

model MenuCategory {
