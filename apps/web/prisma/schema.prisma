  isLowMargin               Boolean                   @default(false) @map("is_low_margin")
  costedAt                  DateTime                  @default(now()) @map("costed_at") @db.Timestamptz(6)
  createdAt                 DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)

  recipe    ProductRecipe?   @relation(fields: [recipeId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  menuItem  MenuItem?        @relation(fields: [menuItemId], references: [id], onDelete: SetNull, onUpdate: NoAction)
