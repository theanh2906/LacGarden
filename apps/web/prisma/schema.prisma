model Payment {
  id                   String                      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderId              String                      @map("order_id") @db.Uuid
  shiftId              String?                     @map("shift_id") @db.Uuid
  method               PaymentMethod
  status               PaymentRecordStatus         @default(CONFIRMED)
  amount               BigInt
  receivedAmount       BigInt?                     @map("received_amount")
  changeAmount         BigInt                      @default(0) @map("change_amount")
  paidAmount           BigInt?                     @map("paid_amount")
  paidAt               DateTime?                   @map("paid_at") @db.Timestamptz(6)
  provider             String?
  providerReference    String?                     @map("provider_reference")
  reconciliationStatus PaymentReconciliationStatus @default(NOT_REQUIRED) @map("reconciliation_status")
  expiresAt            DateTime?                   @map("expires_at") @db.Timestamptz(6)
  note                 String?
  confirmedById        String                      @map("confirmed_by_id") @db.Uuid
  createdAt            DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)

  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  shift       Shift? @relation(fields: [shiftId], references: [id], onUpdate: NoAction)
  confirmedBy User   @relation(fields: [confirmedById], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([confirmedById], map: "payments_confirmedById_idx")
  @@index([createdAt], map: "payments_createdAt_idx")
  @@index([providerReference], map: "payments_providerReference_idx")
  @@index([reconciliationStatus, expiresAt], map: "payments_reconciliationStatus_expiresAt_idx")
  @@index([method, status])
  @@index([orderId], map: "payments_orderId_idx")
  @@index([shiftId], map: "payments_shiftId_idx")
  @@map("payments")
}

