  @@index([menuItemId, createdAt], map: "product_cost_snapshots_menuItemId_createdAt_idx")
  @@index([variantId, createdAt], map: "product_cost_snapshots_variantId_createdAt_idx")
  @@index([targetKey, createdAt], map: "product_cost_snapshots_targetKey_createdAt_idx")
  @@index([source, createdAt], map: "product_cost_snapshots_source_createdAt_idx")
  @@map("product_cost_snapshots")
}

